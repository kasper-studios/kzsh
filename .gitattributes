# Enforce LF for scripts/configs to avoid bash/zsh CRLF issues on Linux
# (CRLF breaks shebang parsing and can cause: syntax error near unexpected token `$'\r'`)

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# systemd / config
*.service text eol=lf
*.conf text eol=lf
*.desktop text eol=lf
*.kdl text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Docs are not critical, keep default behavior
*.md text
